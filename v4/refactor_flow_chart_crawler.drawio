        <mxCell id="H3wLTHg_EMBFDXoFke4Y-4" value="&lt;div&gt;&lt;div style=&quot;line-height: 18px;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;sync表last_date有資料：&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;ul style=&quot;&quot;&gt;&lt;li&gt;&lt;font style=&quot;font-size: 10px; background-color: rgb(255, 255, 255);&quot;&gt;錯誤：last_date &amp;gt;= today =&amp;gt; start = today&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 10px; background-color: rgb(255, 255, 255);&quot;&gt;正確：start為last_date + 1&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font&gt;&lt;b style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;sync表無資料：&lt;/span&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul style=&quot;&quot;&gt;&lt;li style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 10px; background-color: rgb(255, 255, 255);&quot;&gt;日期錯誤：使用硬基礎日_HARD_BASELINE&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 10px; background-color: rgb(255, 255, 255);&quot;&gt;成立日較大：使用成立日inception_date&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 10px; background-color: rgb(255, 255, 255);&quot;&gt;預設起始日較大：使用預設起始日DEFAULT_START_DATE&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[1,1,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];rounded=1;absoluteArcSize=1;arcSize=2;html=1;strokeColor=none;gradientColor=none;shadow=0;dashed=0;fontSize=12;fontColor=#000000;align=left;verticalAlign=top;spacing=10;spacingTop=-4;whiteSpace=wrap;fillColor=none;labelBackgroundColor=none;" parent="1" vertex="1">

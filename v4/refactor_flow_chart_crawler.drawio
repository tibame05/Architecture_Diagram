        <mxCell id="pBn1wElCEaNdD46zVSjh-9" value="&lt;div&gt;&lt;span style=&quot;font-family: -webkit-standard; caret-color: rgb(0, 0, 0); background-color: initial;&quot;&gt;&lt;font color=&quot;#cc6600&quot; style=&quot;font-size: 12px;&quot;&gt;&lt;b&gt;依地區計算 TRI：&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;b style=&quot;background-color: initial; color: rgb(0, 0, 0);&quot;&gt;計算該&lt;/b&gt;&lt;b style=&quot;color: rgb(0, 0, 0); background-color: rgb(255, 242, 204);&quot;&gt;etf_id&lt;/b&gt;&lt;b style=&quot;background-color: initial; color: rgb(0, 0, 0);&quot;&gt;的tri，計算方式：&lt;/b&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;美股：&lt;/font&gt;&lt;span style=&quot;caret-color: rgb(0, 0, 0);&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;使用「調整後收盤價」(Adjusted Close) 連乘&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;台股：&lt;/font&gt;&lt;span style=&quot;background-image: initial; background-position: initial; background-size: initial; background-repeat: initial; background-attachment: initial; background-origin: initial; background-clip: initial; isolation: auto;&quot; class=&quot;notion-enable-hover&quot; data-token-index=&quot;0&quot;&gt;&lt;span style=&quot;caret-color: rgb(0, 0, 0);&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;使用「(收盤價 + 單位股利) / 前一收盤價」連乘&lt;/font&gt;&lt;/span&gt;&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;caret-color: rgb(0, 0, 0);&quot;&gt;&lt;font color=&quot;#cc6600&quot;&gt;&lt;b&gt;寫入資料庫與回傳：&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;b style=&quot;background-color: initial; color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;background-color: initial; color: rgb(0, 0, 0);&quot;&gt;用&lt;/b&gt;&lt;b style=&quot;color: rgb(0, 0, 0); background-color: rgb(248, 206, 204);&quot;&gt;write_etf_tris_to_db&lt;/b&gt;&lt;b style=&quot;color: rgb(0, 0, 0);&quot;&gt;寫入資料庫，&lt;/b&gt;&lt;b style=&quot;background-color: initial; color: rgb(0, 0, 0);&quot;&gt;來新增&lt;/b&gt;&lt;span style=&quot;background: rgb(213, 232, 212); isolation: auto;&quot; class=&quot;notion-enable-hover&quot; data-token-index=&quot;0&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;b&gt;etf_tris&lt;/b&gt;&lt;/font&gt;&lt;/span&gt;&lt;b style=&quot;background-color: initial;&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;span style=&quot;background: rgb(213, 232, 212); isolation: auto;&quot; class=&quot;notion-enable-hover&quot; data-token-index=&quot;0&quot;&gt;資料表&lt;/span&gt;&lt;/font&gt;&lt;/b&gt;&lt;b style=&quot;background-color: initial; color: rgb(0, 0, 0);&quot;&gt;資料。&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: initial; color: rgb(0, 0, 0);&quot;&gt;回傳最後計算完tir的&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&lt;font style=&quot;background-color: rgb(255, 242, 204);&quot; color=&quot;#000000&quot;&gt;last_tri_date&lt;/font&gt;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;增加的筆數&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[1,0.25,0],[1,0.5,0],[1,0.75,0],[1,1,0],[0.75,1,0],[0.5,1,0],[0.25,1,0],[0,1,0],[0,0.75,0],[0,0.5,0],[0,0.25,0]];rounded=1;absoluteArcSize=1;arcSize=2;html=1;strokeColor=#000000;gradientColor=none;shadow=0;dashed=0;fontSize=12;fontColor=#9E9E9E;align=left;verticalAlign=top;spacing=10;spacingTop=-4;whiteSpace=wrap;" parent="1" vertex="1">
